{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "fluid": true,
  "services": {
    "frontend": {
      "root": "frontend",
      "buildCommand": "node scripts/prepare-games.js",
      "outputDirectory": "."
    },
    "proxy": {
      "root": "proxy",
      "framework": "express",
      "entrypoint": "server.js"
    }
  },
  "rewrites": [
    { "source": "/api/proxy", "destination": { "service": "proxy" } },
    { "source": "/uv/(.*)", "destination": { "service": "proxy" } },
    { "source": "/baremux/(.*)", "destination": { "service": "proxy" } },
    { "source": "/epoxy/(.*)", "destination": { "service": "proxy" } },
    { "source": "/service/(.*)", "destination": { "service": "proxy" } },
    { "source": "/wisp/(.*)", "destination": { "service": "proxy" } },
    { "source": "/sw.js", "destination": { "service": "proxy" } },
    { "source": "/(.*)", "destination": { "service": "frontend" } }
  ]
}
